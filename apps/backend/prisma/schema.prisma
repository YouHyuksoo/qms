// ──────────────────────────────────────────────
// Models
// ──────────────────────────────────────────────

/// 1. 검사 LOT
model InspectionLot {
  lotNo          String              @id @map("LOT_NO") @db.VarChar(50)
  itemCode       String              @map("ITEM_CODE") @db.VarChar(50)
  itemName       String?             @map("ITEM_NAME") @db.VarChar(200)
  inspectionType InspectionType      @map("INSPECTION_TYPE")
  inspectionDate DateTime?           @map("INSPECTION_DATE")
  inspector      String?             @map("INSPECTOR") @db.VarChar(100)
  lotQty         Int                 @default(0) @map("LOT_QTY")
  sampleQty      Int                 @default(0) @map("SAMPLE_QTY")
  judgment       InspectionJudgment? @map("JUDGMENT")
  status         InspectionStatus    @default(PENDING) @map("STATUS")
  supplierCode   String?             @map("SUPPLIER_CODE") @db.VarChar(50)
  supplierName   String?             @map("SUPPLIER_NAME") @db.VarChar(200)
  poNo           String?             @map("PO_NO") @db.VarChar(50)
  workOrderNo    String?             @map("WORK_ORDER_NO") @db.VarChar(50)
  remarks        String?             @map("REMARKS") @db.VarChar(2000)
  ncrNo          String?             @map("NCR_NO") @db.VarChar(50)

  createdAt DateTime  @default(now()) @map("CREATED_AT")
  updatedAt DateTime  @updatedAt @map("UPDATED_AT")
  deletedAt DateTime? @map("DELETED_AT")
  createdBy String?   @map("CREATED_BY") @db.VarChar(100)
  updatedBy String?   @map("UPDATED_BY") @db.VarChar(100)

  results InspectionResult[]

  @@map("QMS_INSPECTION_LOT")
}

/// 2. 검사 결과
model InspectionResult {
  resultId            String          @id @default(uuid()) @map("RESULT_ID") @db.VarChar(50)
  lotNo               String          @map("LOT_NO") @db.VarChar(50)
  characteristicName  String          @map("CHARACTERISTIC_NAME") @db.VarChar(200)
  characteristicNo    String?         @map("CHARACTERISTIC_NO") @db.VarChar(50)
  specMin             Decimal?        @map("SPEC_MIN") @db.Decimal(18, 6)
  specMax             Decimal?        @map("SPEC_MAX") @db.Decimal(18, 6)
  specText            String?         @map("SPEC_TEXT") @db.VarChar(500)
  measuredValue       Decimal?        @map("MEASURED_VALUE") @db.Decimal(18, 6)
  measuredText        String?         @map("MEASURED_TEXT") @db.VarChar(500)
  judgment            ResultJudgment? @map("JUDGMENT")
  inspectionMethod    String?         @map("INSPECTION_METHOD") @db.VarChar(200)
  inspectionEquipment String?         @map("INSPECTION_EQUIPMENT") @db.VarChar(200)
  remarks             String?         @map("REMARKS") @db.VarChar(2000)
  sequenceNo          Int             @default(1) @map("SEQUENCE_NO")

  createdAt DateTime  @default(now()) @map("CREATED_AT")
  updatedAt DateTime  @updatedAt @map("UPDATED_AT")
  deletedAt DateTime? @map("DELETED_AT")
  createdBy String?   @map("CREATED_BY") @db.VarChar(100)
  updatedBy String?   @map("UPDATED_BY") @db.VarChar(100)

  lot InspectionLot @relation(fields: [lotNo], references: [lotNo], onDelete: Cascade)

  @@map("QMS_INSPECTION_RESULT")
}

/// 3. 부적합 보고서 (NCR)
model Ncr {
  ncrNo            String      @id @map("NCR_NO") @db.VarChar(50)
  title            String      @map("TITLE") @db.VarChar(500)
  description      String?     @map("DESCRIPTION") @db.VarChar(4000)
  occurrenceDate   DateTime?   @map("OCCURRENCE_DATE")
  lotNo            String?     @map("LOT_NO") @db.VarChar(50)
  itemCode         String?     @map("ITEM_CODE") @db.VarChar(50)
  itemName         String?     @map("ITEM_NAME") @db.VarChar(200)
  defectQty        Int         @default(0) @map("DEFECT_QTY")
  defectType       DefectType? @map("DEFECT_TYPE")
  status           NcrStatus   @default(DRAFT) @map("STATUS")
  source           NcrSource?  @map("SOURCE")
  reportedBy       String?     @map("REPORTED_BY") @db.VarChar(100)
  reportedDate     DateTime?   @map("REPORTED_DATE")
  assignedTo       String?     @map("ASSIGNED_TO") @db.VarChar(100)
  dueDate          DateTime?   @map("DUE_DATE")
  rootCause        String?     @map("ROOT_CAUSE") @db.VarChar(4000)
  correctiveAction String?     @map("CORRECTIVE_ACTION") @db.VarChar(4000)
  preventiveAction String?     @map("PREVENTIVE_ACTION") @db.VarChar(4000)
  closedDate       DateTime?   @map("CLOSED_DATE")
  closedBy         String?     @map("CLOSED_BY") @db.VarChar(100)
  remarks          String?     @map("REMARKS") @db.VarChar(2000)

  createdAt DateTime  @default(now()) @map("CREATED_AT")
  updatedAt DateTime  @updatedAt @map("UPDATED_AT")
  deletedAt DateTime? @map("DELETED_AT")
  createdBy String?   @map("CREATED_BY") @db.VarChar(100)
  updatedBy String?   @map("UPDATED_BY") @db.VarChar(100)

  mrbReviews MrbReview[]

  @@map("QMS_NCR")
}

/// 4. MRB 검토
model MrbReview {
  reviewId        String           @id @default(uuid()) @map("REVIEW_ID") @db.VarChar(50)
  ncrNo           String           @map("NCR_NO") @db.VarChar(50)
  reviewedBy      String           @map("REVIEWED_BY") @db.VarChar(100)
  reviewDate      DateTime         @map("REVIEW_DATE")
  disposition     DispositionType? @map("DISPOSITION")
  reason          String?          @map("REASON") @db.VarChar(4000)
  approvedBy      String?          @map("APPROVED_BY") @db.VarChar(100)
  approvedDate    DateTime?        @map("APPROVED_DATE")
  status          ReviewStatus     @default(PENDING) @map("STATUS")
  executionDate   DateTime?        @map("EXECUTION_DATE")
  executionResult String?          @map("EXECUTION_RESULT") @db.VarChar(2000)
  executedBy      String?          @map("EXECUTED_BY") @db.VarChar(100)
  attachments     String?          @map("ATTACHMENTS") @db.VarChar(4000)
  remarks         String?          @map("REMARKS") @db.VarChar(2000)

  createdAt DateTime  @default(now()) @map("CREATED_AT")
  updatedAt DateTime  @updatedAt @map("UPDATED_AT")
  deletedAt DateTime? @map("DELETED_AT")
  createdBy String?   @map("CREATED_BY") @db.VarChar(100)
  updatedBy String?   @map("UPDATED_BY") @db.VarChar(100)

  ncr Ncr @relation(fields: [ncrNo], references: [ncrNo], onDelete: Cascade)

  @@map("QMS_MRB_REVIEW")
}

/// 5. APQP 프로젝트
model ApqpProject {
  projectNo          String            @id @map("PROJECT_NO") @db.VarChar(50)
  projectName        String            @map("PROJECT_NAME") @db.VarChar(200)
  customerCode       String?           @map("CUSTOMER_CODE") @db.VarChar(50)
  customerName       String?           @map("CUSTOMER_NAME") @db.VarChar(200)
  itemCode           String?           @map("ITEM_CODE") @db.VarChar(50)
  itemName           String?           @map("ITEM_NAME") @db.VarChar(200)
  plannedStartDate   DateTime?         @map("PLANNED_START_DATE")
  plannedEndDate     DateTime?         @map("PLANNED_END_DATE")
  actualStartDate    DateTime?         @map("ACTUAL_START_DATE")
  actualEndDate      DateTime?         @map("ACTUAL_END_DATE")
  projectManager     String?           @map("PROJECT_MANAGER") @db.VarChar(100)
  status             ApqpProjectStatus @default(PLANNING) @map("STATUS")
  targetQualityLevel Decimal?          @default(99.0) @map("TARGET_QUALITY_LEVEL") @db.Decimal(5, 2)
  actualQualityLevel Decimal?          @map("ACTUAL_QUALITY_LEVEL") @db.Decimal(5, 2)
  remarks            String?           @map("REMARKS") @db.VarChar(2000)

  createdAt DateTime  @default(now()) @map("CREATED_AT")
  updatedAt DateTime  @updatedAt @map("UPDATED_AT")
  deletedAt DateTime? @map("DELETED_AT")
  createdBy String?   @map("CREATED_BY") @db.VarChar(100)
  updatedBy String?   @map("UPDATED_BY") @db.VarChar(100)

  phases ApqpPhase[]

  @@map("QMS_APQP_PROJECT")
}

/// 6. APQP 단계
model ApqpPhase {
  phaseId            String          @id @default(uuid()) @map("PHASE_ID") @db.VarChar(50)
  projectNo          String          @map("PROJECT_NO") @db.VarChar(50)
  phaseType          ApqpPhaseType   @map("PHASE_TYPE")
  phaseName          String          @map("PHASE_NAME") @db.VarChar(200)
  sequenceNo         Int             @default(1) @map("SEQUENCE_NO")
  plannedStartDate   DateTime?       @map("PLANNED_START_DATE")
  plannedEndDate     DateTime?       @map("PLANNED_END_DATE")
  actualStartDate    DateTime?       @map("ACTUAL_START_DATE")
  actualEndDate      DateTime?       @map("ACTUAL_END_DATE")
  targetQualityLevel Decimal?        @map("TARGET_QUALITY_LEVEL") @db.Decimal(5, 2)
  actualQualityLevel Decimal?        @map("ACTUAL_QUALITY_LEVEL") @db.Decimal(5, 2)
  status             ApqpPhaseStatus @default(NOT_STARTED) @map("STATUS")
  approvedBy         String?         @map("APPROVED_BY") @db.VarChar(100)
  approvedDate       DateTime?       @map("APPROVED_DATE")
  rejectionReason    String?         @map("REJECTION_REASON") @db.VarChar(2000)
  remarks            String?         @map("REMARKS") @db.VarChar(2000)

  createdAt DateTime  @default(now()) @map("CREATED_AT")
  updatedAt DateTime  @updatedAt @map("UPDATED_AT")
  deletedAt DateTime? @map("DELETED_AT")
  createdBy String?   @map("CREATED_BY") @db.VarChar(100)
  updatedBy String?   @map("UPDATED_BY") @db.VarChar(100)

  project      ApqpProject       @relation(fields: [projectNo], references: [projectNo], onDelete: Cascade)
  deliverables GateDeliverable[]

  @@map("QMS_APQP_PHASE")
}

/// 7. Gate 산출물
model GateDeliverable {
  deliverableId   String            @id @default(uuid()) @map("DELIVERABLE_ID") @db.VarChar(50)
  phaseId         String            @map("PHASE_ID") @db.VarChar(50)
  deliverableName String            @map("DELIVERABLE_NAME") @db.VarChar(200)
  deliverableCode String?           @map("DELIVERABLE_CODE") @db.VarChar(50)
  isRequired      Boolean           @default(true) @map("IS_REQUIRED")
  isSubmitted     Boolean           @default(false) @map("IS_SUBMITTED")
  submittedDate   DateTime?         @map("SUBMITTED_DATE")
  submittedBy     String?           @map("SUBMITTED_BY") @db.VarChar(100)
  status          DeliverableStatus @default(NOT_SUBMITTED) @map("STATUS")
  approvedDate    DateTime?         @map("APPROVED_DATE")
  approvedBy      String?           @map("APPROVED_BY") @db.VarChar(100)
  documentPath    String?           @map("DOCUMENT_PATH") @db.VarChar(500)
  remarks         String?           @map("REMARKS") @db.VarChar(2000)

  createdAt DateTime  @default(now()) @map("CREATED_AT")
  updatedAt DateTime  @updatedAt @map("UPDATED_AT")
  deletedAt DateTime? @map("DELETED_AT")
  createdBy String?   @map("CREATED_BY") @db.VarChar(100)
  updatedBy String?   @map("UPDATED_BY") @db.VarChar(100)

  phase ApqpPhase @relation(fields: [phaseId], references: [phaseId], onDelete: Cascade)

  @@map("QMS_GATE_DELIVERABLE")
}

/// 8. PPAP 제출
model PpapSubmission {
  submissionId      String     @id @default(uuid()) @map("SUBMISSION_ID") @db.VarChar(50)
  projectNo         String     @map("PROJECT_NO") @db.VarChar(50)
  submissionNo      String     @map("SUBMISSION_NO") @db.VarChar(50)
  submissionLevel   Int        @default(3) @map("SUBMISSION_LEVEL")
  submissionDate    DateTime?  @map("SUBMISSION_DATE")
  customerCode      String?    @map("CUSTOMER_CODE") @db.VarChar(50)
  customerName      String?    @map("CUSTOMER_NAME") @db.VarChar(200)
  status            PpapStatus @default(NOT_SUBMITTED) @map("STATUS")
  pswNo             String?    @map("PSW_NO") @db.VarChar(50)
  pswPath           String?    @map("PSW_PATH") @db.VarChar(500)
  reviewedBy        String?    @map("REVIEWED_BY") @db.VarChar(100)
  reviewDate        DateTime?  @map("REVIEW_DATE")
  rejectionReason   String?    @map("REJECTION_REASON") @db.VarChar(2000)
  resubmissionDate  DateTime?  @map("RESUBMISSION_DATE")
  resubmissionCount Int        @default(0) @map("RESUBMISSION_COUNT")
  approvalDeadline  DateTime?  @map("APPROVAL_DEADLINE")
  remarks           String?    @map("REMARKS") @db.VarChar(2000)

  createdAt DateTime  @default(now()) @map("CREATED_AT")
  updatedAt DateTime  @updatedAt @map("UPDATED_AT")
  deletedAt DateTime? @map("DELETED_AT")
  createdBy String?   @map("CREATED_BY") @db.VarChar(100)
  updatedBy String?   @map("UPDATED_BY") @db.VarChar(100)

  documents       PpapDocument[]
  approvalHistory PpapApprovalHistory[]

  @@map("QMS_PPAP_SUBMISSION")
}

/// 9. PPAP 문서
model PpapDocument {
  documentId    String           @id @default(uuid()) @map("DOCUMENT_ID") @db.VarChar(50)
  submissionId  String           @map("SUBMISSION_ID") @db.VarChar(50)
  documentType  PpapDocumentType @map("DOCUMENT_TYPE")
  documentName  String           @map("DOCUMENT_NAME") @db.VarChar(200)
  documentCode  String?          @map("DOCUMENT_CODE") @db.VarChar(50)
  isRequired    Boolean          @default(true) @map("IS_REQUIRED")
  isSubmitted   Boolean          @default(false) @map("IS_SUBMITTED")
  submittedDate DateTime?        @map("SUBMITTED_DATE")
  status        DocumentStatus   @default(NOT_SUBMITTED) @map("STATUS")
  documentPath  String?          @map("DOCUMENT_PATH") @db.VarChar(500)
  version       String?          @map("VERSION") @db.VarChar(20)
  reviewedBy    String?          @map("REVIEWED_BY") @db.VarChar(100)
  reviewDate    DateTime?        @map("REVIEW_DATE")
  remarks       String?          @map("REMARKS") @db.VarChar(2000)

  createdAt DateTime  @default(now()) @map("CREATED_AT")
  updatedAt DateTime  @updatedAt @map("UPDATED_AT")
  deletedAt DateTime? @map("DELETED_AT")
  createdBy String?   @map("CREATED_BY") @db.VarChar(100)
  updatedBy String?   @map("UPDATED_BY") @db.VarChar(100)

  submission PpapSubmission @relation(fields: [submissionId], references: [submissionId], onDelete: Cascade)

  @@map("QMS_PPAP_DOCUMENT")
}

/// 10. PPAP 승인 이력
model PpapApprovalHistory {
  historyId      String         @id @default(uuid()) @map("HISTORY_ID") @db.VarChar(50)
  submissionId   String         @map("SUBMISSION_ID") @db.VarChar(50)
  action         ApprovalAction @map("ACTION")
  actionDate     DateTime       @map("ACTION_DATE")
  actionBy       String         @map("ACTION_BY") @db.VarChar(100)
  reason         String?        @map("REASON") @db.VarChar(2000)
  previousStatus String?        @map("PREVIOUS_STATUS") @db.VarChar(50)
  newStatus      String         @map("NEW_STATUS") @db.VarChar(50)
  remarks        String?        @map("REMARKS") @db.VarChar(2000)

  createdAt DateTime  @default(now()) @map("CREATED_AT")
  updatedAt DateTime  @updatedAt @map("UPDATED_AT")
  deletedAt DateTime? @map("DELETED_AT")
  createdBy String?   @map("CREATED_BY") @db.VarChar(100)
  updatedBy String?   @map("UPDATED_BY") @db.VarChar(100)

  submission PpapSubmission @relation(fields: [submissionId], references: [submissionId], onDelete: Cascade)

  @@map("QMS_PPAP_APPROVAL_HISTORY")
}

/// 11. DVP 계획
model DvpPlan {
  planId             String       @id @default(uuid()) @map("PLAN_ID") @db.VarChar(50)
  projectNo          String       @map("PROJECT_NO") @db.VarChar(50)
  itemCode           String?      @map("ITEM_CODE") @db.VarChar(50)
  itemName           String?      @map("ITEM_NAME") @db.VarChar(200)
  testCategory       TestCategory @map("TEST_CATEGORY")
  testItem           String       @map("TEST_ITEM") @db.VarChar(200)
  testMethod         String?      @map("TEST_METHOD") @db.VarChar(200)
  acceptanceCriteria String?      @map("ACCEPTANCE_CRITERIA") @db.VarChar(500)
  testFacility       String?      @map("TEST_FACILITY") @db.VarChar(200)
  testEquipment      String?      @map("TEST_EQUIPMENT") @db.VarChar(200)
  plannedStartDate   DateTime?    @map("PLANNED_START_DATE")
  plannedEndDate     DateTime?    @map("PLANNED_END_DATE")
  sampleQty          Int?         @default(5) @map("SAMPLE_QTY")
  responsiblePerson  String?      @map("RESPONSIBLE_PERSON") @db.VarChar(100)
  referenceSpec      String?      @map("REFERENCE_SPEC") @db.VarChar(200)
  priority           Int?         @default(1) @map("PRIORITY")
  remarks            String?      @map("REMARKS") @db.VarChar(2000)

  createdAt DateTime  @default(now()) @map("CREATED_AT")
  updatedAt DateTime  @updatedAt @map("UPDATED_AT")
  deletedAt DateTime? @map("DELETED_AT")
  createdBy String?   @map("CREATED_BY") @db.VarChar(100)
  updatedBy String?   @map("UPDATED_BY") @db.VarChar(100)

  results DvpResult[]

  @@map("QMS_DVP_PLAN")
}

/// 12. DVP 결과
model DvpResult {
  resultId          String     @id @default(uuid()) @map("RESULT_ID") @db.VarChar(50)
  planId            String     @map("PLAN_ID") @db.VarChar(50)
  actualStartDate   DateTime?  @map("ACTUAL_START_DATE")
  actualEndDate     DateTime?  @map("ACTUAL_END_DATE")
  testedQty         Int?       @default(0) @map("TESTED_QTY")
  passedQty         Int?       @default(0) @map("PASSED_QTY")
  failedQty         Int?       @default(0) @map("FAILED_QTY")
  testResult        TestResult @default(NOT_TESTED) @map("TEST_RESULT")
  testReportNo      String?    @map("TEST_REPORT_NO") @db.VarChar(50)
  testReportPath    String?    @map("TEST_REPORT_PATH") @db.VarChar(500)
