/**
 * @file schema.prisma
 * @description QMS(Quality Management System) 전체 Prisma 스키마 정의.
 * 26개 테이블 + enum + 관계를 포함하며, Oracle 컬럼명을 @@map / @map 으로 매핑.
 * 뷰 엔티티(ComplaintTrend, WarrantyPpm, FailurePattern)는 raw query 로 처리하므로 제외.
 */

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────

