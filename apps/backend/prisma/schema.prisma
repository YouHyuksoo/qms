  calibratedBy        String?           @map("CALIBRATED_BY") @db.VarChar(100)
  externalLabName     String?           @map("EXTERNAL_LAB_NAME") @db.VarChar(200)
  result              CalibrationResult @default(PASS) @map("RESULT")
  certificateNo       String?           @map("CERTIFICATE_NO") @db.VarChar(50)
  measuredValues      String?           @map("MEASURED_VALUES") @db.VarChar(4000)
  standardValues      String?           @map("STANDARD_VALUES") @db.VarChar(4000)
  deviation           String?           @map("DEVIATION") @db.VarChar(2000)
  uncertainty         String?           @map("UNCERTAINTY") @db.VarChar(500)
  nextCalibrationDate DateTime?         @map("NEXT_CALIBRATION_DATE")
  isOot               Boolean           @default(false) @map("IS_OOT")
  ootAction           String?           @map("OOT_ACTION") @db.VarChar(2000)
  affectedLots        String?           @map("AFFECTED_LOTS") @db.VarChar(4000)
  remarks             String?           @map("REMARKS") @db.VarChar(2000)

  createdAt DateTime  @default(now()) @map("CREATED_AT")
  updatedAt DateTime  @updatedAt @map("UPDATED_AT")
  deletedAt DateTime? @map("DELETED_AT")
  createdBy String?   @map("CREATED_BY") @db.VarChar(100)
  updatedBy String?   @map("UPDATED_BY") @db.VarChar(100)

  equipment Equipment @relation(fields: [equipmentId], references: [equipmentId], onDelete: Cascade)

  @@map("QMS_CALIBRATION")
}

